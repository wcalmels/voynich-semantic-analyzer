# Last edited on 1998-11-23 04:06:10 by stolfi
#
# Identification:
#
#   Title: ???
#   Page: f82r = MO (Rene) = p159 (Stolfi)
#   Folio: f82
#   Panels: f82r
#   Bifolio: bM3 = f77+f82
#   Quire: M (Rene) = XIII (Beinecke)
